rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Price reports: anyone can see them, only logged in users can report
    match /prices/{priceId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false; 
    }

    // User profiles & logs: public can see top-level ranks, but only owners can manage logs
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Sub-collection for fuel logs
      match /logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
