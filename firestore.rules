rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Price reports: anyone can see them, only logged in users can report
    match /prices/{priceId} {
      allow read: if true;
      allow create: if request.auth != null;
      // No updates/deletes for now to maintain history integrity
      allow update, delete: if false; 
    }

    // User profiles: public can see ranks, but only owners can edit
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
